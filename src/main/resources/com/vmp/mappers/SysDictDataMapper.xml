	<!--实体映射-->
	<resultMap id="base_result_map" type="com.vmp.entity.po.SysDictData">
		<!--字典主键id-->
		<result column="dict_id" property="dictId"  />
		<!--父级id, VMP表示一级字典类型-->
		<result column="pid" property="pid"  />
		<!--字典代码-->
		<result column="dict_code" property="dictCode"  />
		<!--字典名称-->
		<result column="dict_name" property="dictName"  />
		<!--0禁用1启用-->
		<result column="status" property="status"  />
		<!--备注-->
		<result column="remark" property="remark"  />
		<!--创建时间-->
		<result column="create_time" property="createTime"  />
	</resultMap>


	<!-- 通用查询结果列-->
	<sql id="base_column_list">
		 dict_id,pid,dict_code,dict_name,status,
		 remark,create_time
	</sql>

	<sql id="base_condition_filed">
		<if test="query.dictId != null and query.dictId!=''">
			 and  dict_id = #{query.dictId}
		</if>
		<if test="query.pid != null and query.pid!=''">
			 and  pid = #{query.pid}
		</if>
		<if test="query.dictCode != null and query.dictCode!=''">
			 and  dict_code = #{query.dictCode}
		</if>
		<if test="query.dictName != null and query.dictName!=''">
			 and  dict_name = #{query.dictName}
		</if>
		<if test="query.status != null">
			 and  status = #{query.status}
		</if>
		<if test="query.remark != null and query.remark!=''">
			 and  remark = #{query.remark}
		</if>
		<if test="query.createTime != null and query.createTime!=''">
			 <![CDATA[ and  create_time=str_to_date(#{query.createTime}, '%Y-%m-%d') ]]>
		</if>
	</sql>

	<!-- 通用查询条件列-->
	<sql id="query_condition">
		<where>
			<include refid="base_condition_filed" />
			<if test="query.dictIdFuzzy!= null  and query.dictIdFuzzy!=''">
				 and  dict_id like concat('%', #{query.dictIdFuzzy}, '%')
			</if>
			<if test="query.pidFuzzy!= null  and query.pidFuzzy!=''">
				 and  pid like concat('%', #{query.pidFuzzy}, '%')
			</if>
			<if test="query.dictCodeFuzzy!= null  and query.dictCodeFuzzy!=''">
				 and  dict_code like concat('%', #{query.dictCodeFuzzy}, '%')
			</if>
			<if test="query.dictNameFuzzy!= null  and query.dictNameFuzzy!=''">
				 and  dict_name like concat('%', #{query.dictNameFuzzy}, '%')
			</if>
			<if test="query.remarkFuzzy!= null  and query.remarkFuzzy!=''">
				 and  remark like concat('%', #{query.remarkFuzzy}, '%')
			</if>
			<if test="query.createTimeStart!= null and query.createTimeStart!=''">
				 <![CDATA[ and  create_time>=str_to_date(#{query.createTimeStart}, '%Y-%m-%d') ]]>
			</if>
			<if test="query.createTimeEnd!= null and query.createTimeEnd!=''">
				 <![CDATA[ and  create_time< date_sub(str_to_date(#{query.createTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
			</if>
		</where>
	</sql>

	<!-- 查询集合-->
	<select id="selectList" resultMap="base_result_map" >
		 SELECT <include refid="base_column_list" /> FROM sys_dict_data <include refid="query_condition" />
		 <if test="query.orderBy!=null">
			 order by ${query.orderBy}
		 </if>
		 <if test="query.simplePage!=null">
			 limit #{query.simplePage.start},#{query.simplePage.end}
		 </if>
	</select>

	<!-- 查询数量-->
	<select id="selectCount" resultType="java.lang.Integer" >
